# ============================================================
# Netclaw .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
.venv/
venv/
env/

# Backend runtime data (all generated by `python cli.py setup`)
# Note: .gitkeep files are kept to ensure directory structure is tracked
# Agent directories are tracked, but specific runtime files are ignored
backend/data/agents/*/log/
backend/data/agents/*/sessions/
backend/data/agents/*/workspace/memory/
backend/data/agents/*/agent_state.json
backend/data/agents/*/storage/
backend/data/subagents/
!backend/data/subagents/.gitkeep
backend/data/cron/
!backend/data/cron/.gitkeep
backend/data/config.json
backend/data/**/logs/
backend/data/**/*.jsonl
backend/data/**/*.db

# Project analysis docs (local development only)
docs-analysis/

# Env files with secrets
backend/.env
!backend/.env.example

# Frontend
frontend/node_modules/
frontend/.next/
frontend/out/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
venv/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test/cache
.pytest_cache/
backend/.pytest_cache/
**/.pytest_cache/
bin/
lib/

# e2e
e2e/
